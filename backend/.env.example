DEBUG=true
APP_NAME=GEO Feedback Optimizer
APP_VERSION=1.1.0

# Local dev default:
DATABASE_URL=sqlite+aiosqlite:///./data/geo_optimizer.db

# Railway production example:
# DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname

DEFAULT_LLM_PROVIDER=zhipu
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4-flash

DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-20241105163904-g7qlg

OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=GEO_Optimizer
OPENROUTER_MODEL=openai/gpt-4o-mini
# Expert-grade models for deep analysis and content generation.
OPENROUTER_ANALYSIS_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_CONTENT_MODEL=google/gemini-2.5-pro-preview

INTERNAL_API_KEY=

FEATURE_WECHAT_RICH_POST=false
FEATURE_PROMPT_PROFILES=true
FEATURE_WORKFLOW_STEPS=true
FEATURE_AGENT_TEAM=true

UPLOAD_DIR=./data/uploads
EXPORT_DIR=./data/exports
MAX_UPLOAD_SIZE=10485760

STORAGE_BACKEND=local
# S3 compatible (optional)
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
